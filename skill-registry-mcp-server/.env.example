# ============================================================================
# skill-registry MCP server — environment configuration
# ============================================================================
#
# SECURITY:
# - Never commit .env to source control (.env is in .gitignore).
# - Treat ARTIFACTORY_ACCESS_TOKEN / ARTIFACTORY_IDENTITY_TOKEN like passwords.
# - In production, populate these values from a secret manager (Vault, AWS
#   Secrets Manager, Azure Key Vault, etc.) rather than a static .env file.
# - Use a dedicated service account with read-only access on the skills
#   repository — not a personal user account.
#
# USAGE:
#   cp .env.example .env
#   # Edit .env and fill in your values, then start the server.
#
# ============================================================================

# ---------------------------------------------------------------------------
# Backend selection
# ---------------------------------------------------------------------------
# Which registry backend to use. Currently only "artifactory" is supported.
SKILL_REGISTRY_BACKEND=artifactory

# ---------------------------------------------------------------------------
# Artifactory connection
# ---------------------------------------------------------------------------
# Your JFrog platform URL. No trailing slash.
# Free trial: https://jfrog.com/start-free/
ARTIFACTORY_PLATFORM_URL=https://<your-id>.jfrog.io

# The Skills repository key in Artifactory.
# Create in JFrog UI: Administration → Repositories → Create Local → Skills
ARTIFACTORY_REPOSITORY=skills-registry-local

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# "bearer" (recommended) or "basic"
ARTIFACTORY_AUTH_METHOD=bearer

# --- Bearer token (recommended) ---
# Generate in JFrog UI: User menu → Edit Profile → Generate an Identity Token
# Or for service accounts: Administration → User Management → Access Tokens
# Scope: read-only on the skills repository. Rotate quarterly.
ARTIFACTORY_ACCESS_TOKEN=<paste-your-identity-token-here>

# --- Basic auth (only used if ARTIFACTORY_AUTH_METHOD=basic) ---
# Uncomment and populate to use basic auth instead of bearer.
# ARTIFACTORY_USERNAME=<your-username-or-email>
# ARTIFACTORY_IDENTITY_TOKEN=<your-password-or-identity-token>

# ---------------------------------------------------------------------------
# Optional connection settings
# ---------------------------------------------------------------------------
# Request timeout in seconds (default: 30)
ARTIFACTORY_TIMEOUT_SECONDS=30

# Verify TLS certificates. Always true in production.
# Set false ONLY for local dev against self-signed certs — never in production.
ARTIFACTORY_VERIFY_TLS=true

# ---------------------------------------------------------------------------
# Optional MCP server settings
# ---------------------------------------------------------------------------
# Logging level: debug | info | warn | error (default: info)
SKILL_REGISTRY_LOG_LEVEL=info

# Local directory for downloaded skills (default: ~/.cache/skill-registry)
# SKILL_REGISTRY_CACHE_DIR=/path/to/cache

# Max requests per minute to the backend (default: 60)
SKILL_REGISTRY_RATE_LIMIT_RPM=60
