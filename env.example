# ============================================================================
# skill-registry MCP server — environment configuration
# ============================================================================
#
# This file configures the skill-registry MCP server to connect to a JFrog
# Artifactory instance hosting a Skills repository.
#
# SECURITY:
# - Never commit this file to source control. Add `.env` to .gitignore.
# - Never share the access token. Treat it like a password.
# - For production, source these values from a secret manager (Vault, AWS
#   Secrets Manager, Azure Key Vault, etc.) rather than a static .env file.
# - Generate the access token from a dedicated service account, not a personal
#   user account. Scope it to read-only on the skills repository.
#
# ============================================================================

# ---------------------------------------------------------------------------
# Backend selection
# ---------------------------------------------------------------------------
# Which registry backend the MCP server should use. Currently only
# "artifactory" is supported.
SKILL_REGISTRY_BACKEND=artifactory

# ---------------------------------------------------------------------------
# Artifactory connection
# ---------------------------------------------------------------------------
# Your JFrog platform URL. Do not include a trailing slash.
ARTIFACTORY_PLATFORM_URL=https://<paste-your-name-here>.jfrog.io

# The name of the Skills repository in Artifactory.
# Create this in the JFrog UI:
#   Administration → Repositories → Create a Repository → Local
#   Package type: Skills
#   Repository key: skills-registry-local (or your chosen name)
ARTIFACTORY_REPOSITORY=skills-registry-local

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Authentication method: "bearer" (recommended) or "basic".
ARTIFACTORY_AUTH_METHOD=bearer

# --- Bearer token authentication (recommended) ---
# Generate an identity token in the JFrog UI:
#   Top-right user menu → Edit Profile → Generate an Identity Token
# Or, for service accounts:
#   Administration → User Management → Access Tokens → Generate Token
#
# Recommended scope: read-only on the skills repository.
# Recommended expiration: 90 days, with quarterly rotation.
ARTIFACTORY_ACCESS_TOKEN=<paste-your-identity-token-here>

# --- Basic authentication (alternative — only used if AUTH_METHOD=basic) ---
# Uncomment and populate if using basic auth instead of bearer.
# ARTIFACTORY_USERNAME=<your-username>
# ARTIFACTORY_IDENTITY_TOKEN=<your-identity-token>

# ---------------------------------------------------------------------------
# Optional connection settings
# ---------------------------------------------------------------------------
# Request timeout in seconds.
ARTIFACTORY_TIMEOUT_SECONDS=30

# Whether to verify TLS certificates. Always true in production.
# Only set to false for local development against self-signed certs, never
# in any environment connected to a real registry.
ARTIFACTORY_VERIFY_TLS=true

# ---------------------------------------------------------------------------
# Optional MCP server settings
# ---------------------------------------------------------------------------
# Logging level: debug | info | warn | error
SKILL_REGISTRY_LOG_LEVEL=info

# Local cache directory for installed skills (used by install_skill tool).
# Defaults to ~/.cache/skill-registry if unset.
# SKILL_REGISTRY_CACHE_DIR=/path/to/cache

# Rate limit: maximum requests per minute to the backend. Helps avoid
# overwhelming Artifactory and respects shared rate limits.
SKILL_REGISTRY_RATE_LIMIT_RPM=60
